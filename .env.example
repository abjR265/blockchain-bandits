# Copy to .env and fill in. Never commit the real .env.

# ---- Supabase (DB + auth) ----
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, bypass RLS
DATABASE_URL=postgresql://postgres:<pw>@<host>:5432/postgres

# ---- Modal (GPU inference) ----
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=blockchain-bandits

# ---- Cloudflare R2 (blob storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=blockchain-bandits

# ---- Google Cloud (BigQuery) ----
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/gcp-service-account.json
GCP_PROJECT_ID=

# ---- Weights & Biases ----
WANDB_API_KEY=
WANDB_PROJECT=blockchain-bandits
WANDB_ENTITY=

# ---- Etherscan (label enrichment) ----
ETHERSCAN_API_KEY=

# ---- Anthropic (optional LLM explanations) ----
ANTHROPIC_API_KEY=

# ---- Sentry ----
SENTRY_DSN=

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ---- API ----
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development   # development | staging | production
