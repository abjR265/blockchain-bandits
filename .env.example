# Copy to .env and fill in. Never commit the real .env.

# ---- Supabase (Postgres) ----
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:<pw>@<host>:5432/postgres

# ---- Google Cloud (BigQuery) ----
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/gcp-service-account.json
GCP_PROJECT_ID=

# ---- Weights & Biases (rubric point from Assignment 1) ----
WANDB_API_KEY=
WANDB_PROJECT=blockchain-bandits

# ---- Etherscan (required for live mainnet features in API) ----
# https://etherscan.io/apis — used to pull real tx history per address.
ETHERSCAN_API_KEY=
# Ethereum mainnet = 1 (Etherscan API v2 chainid)
ETHERSCAN_CHAIN_ID=1
# Set true only for offline demos without Etherscan (synthetic txs, not real chain).
ALLOW_SYNTHETIC_FEATURES=false
# Set true only for legacy hash-based mock scores (not recommended).
ALLOW_MOCK_SCORER=false

# ---- Anthropic (optional: "Ask Claude to interpret" button) ----
ANTHROPIC_API_KEY=

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- API ----
API_PORT=8000
# Browser origins allowed to call the API (comma-separated). If empty, defaults to http://localhost:3000.
API_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
# Trained booster (optional). Default points at repo ml/checkpoints after training.
MODEL_PATH=../ml/checkpoints/xgb.json
